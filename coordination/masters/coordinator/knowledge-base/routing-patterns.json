  "routing_rules": {
    "parallel_activation": {
      "description": "Activate multiple experts when confidence is split",
      "example": "Security vulnerability in a feature: activate both security + development",
      "trigger_threshold": 0.50
    },
    "sparse_activation": {
      "description": "Only activate experts above minimum threshold",
      "rationale": "Like MoE activating 1B/7B params, only use what's needed"
    },
    "confidence_weighted": {
      "description": "Primary expert gets full task, secondary experts provide support",
      "example": "70% dev, 55% security: dev is primary, security reviews"
    },
    "type_based_routing": {
      "description": "Task type prefixes provide highest confidence (95%)",
      "types": {
        "security": ["security-scan", "security-audit", "cve", "vulnerability", "security-fix", "compliance-check", "penetration-test", "secrets-scan"],
        "development": ["feature", "bug-fix", "refactor", "optimization", "development", "enhancement", "implementation", "improvement", "fix", "update", "add", "create", "modify"],
        "inventory": ["inventory", "catalog", "discovery", "documentation", "doc", "readme", "changelog", "wiki", "guide", "report", "list", "document"],
        "cicd": ["build", "deploy", "test", "ci-cd", "release", "rollback", "pipeline", "workflow", "automation", "publish"]
      }
    }
  },
  "merge_strategies": {
    "sequential": {
      "description": "Results flow from one expert to next",
      "example": "Development implements -> Security reviews -> Inventory documents"
    },
    "parallel": {
      "description": "Experts work independently, results aggregated",
      "example": "Multiple repos scanned in parallel"
    },
    "voting": {
      "description": "Multiple experts vote on best approach",
      "example": "Conflicting solutions from different experts"
    },
    "weighted": {
      "description": "Results weighted by expert confidence",
      "example": "Combine recommendations based on confidence scores"
    }
  },
  "scoring_algorithm": {
    "description": "Additive keyword scoring with booster multipliers",
    "formula": "(keyword_matches * 25) + (booster_matches * 12) - (negative_matches * 30)",
    "normalization": "Clamped to 0-100 range",
    "notes": [
      "2-3 activation keywords + 1-2 boosters typically yield 70+ confidence",
      "Negative indicators can significantly reduce confidence",
      "Type-based routing provides 95% confidence for explicit prefixes",
      "Lowered single_expert threshold to 70% for better single-expert routing"
    ]
  },
