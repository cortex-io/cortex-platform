  },
  "routing_rules": {
    "parallel_activation": {
      "description": "Activate multiple experts when confidence is split",
      "example": "Security vulnerability in a feature → activate both security + development"
    },
    "sparse_activation": {
      "description": "Only activate experts above minimum threshold",
      "rationale": "Like MoE activating 1B/7B params, only use what's needed"
    },
    "confidence_weighted": {
      "description": "Primary expert gets full task, secondary experts provide support",
      "example": "80% dev, 65% security → dev is primary, security reviews"
    }
  },
  "merge_strategies": {
    "sequential": {
      "description": "Results flow from one expert to next",
      "example": "Development implements → Security reviews → Inventory documents"
    },
    "parallel": {
      "description": "Experts work independently, results aggregated",
      "example": "Multiple repos scanned in parallel"
    },
    "voting": {
      "description": "Multiple experts vote on best approach",
      "example": "Conflicting solutions from different experts"
    },
    "weighted": {
      "description": "Results weighted by expert confidence",
      "example": "Combine recommendations based on confidence scores"
    }
  }
}
